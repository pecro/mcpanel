# Required. Picks the auth backend.
#   builtin          — built-in single-admin password + signed-cookie sessions
#   forward-headers  — Authelia / Authentik / Pocket-ID etc. set Remote-User
AUTH_MODE=builtin

# Required when AUTH_MODE=builtin (only on the first boot — once hashed and
# persisted to auth-state.json the env can be removed). The _FILE variant
# takes a path to a file containing the password, for Docker secrets.
MC_ADMIN_PASSWORD=changeme
# MC_ADMIN_PASSWORD_FILE=/run/secrets/mcpanel_admin_password

# Set to false ONLY for local-dev HTTP. Default true sets the Secure flag
# on session and CSRF cookies so they're not sent over plain HTTP.
# MC_COOKIE_SECURE=true

# How long a login lasts before the user has to sign in again.
# MC_SESSION_TTL_DAYS=7

# Required (single-value form). Absolute host path where mcpanel stores
# worlds, backups, and imports. mcpanel uses this exact string when
# constructing bind mounts on spawned world containers, so the path inside
# the panel container must equal the path on the host. Anywhere writable
# by PUID:PGID works on a normal Linux Docker engine.
MC_DATA_ROOT=/var/lib/mcpanel

# Split form. Use these only when the host path and the in-container path
# can't be identical (Docker Desktop file sharing, Podman, userns-remapped
# rootless Docker). Either one alone overrides MC_DATA_ROOT for that side.
# MC_HOST_DATA_ROOT=/var/lib/mcpanel
# MC_CONTAINER_DATA_ROOT=/data/minecraft

# UID / GID for files created by mcpanel and spawned worlds.
# PUID=1000
# PGID=1000

# Timezone used by the panel and inside spawned worlds.
# TZ=America/New_York

# Hostname shown to players as the connect string in the panel UI. If
# unset, the UI uses whatever Host header the browser sent.
# MINECRAFT_HOSTNAME=mcpanel.example.com

# Role group names mcpanel reads from the Remote-Groups header. Override
# to match the group names your identity provider already uses.
# MC_ADMIN_GROUP=mc-admin
# MC_OPERATOR_GROUP=mc-operator
# MC_USER_GROUP=mc-user

# Host port range allocated to spawned world containers.
# MC_PORT_RANGE_START=35550
# MC_PORT_RANGE_END=35559

# Host port the panel UI listens on.
# MCPANEL_HTTP_PORT=8000

# Optional: Apprise endpoint for the dual-awake watchdog. Leave empty to
# only log events.
# APPRISE_URL=
