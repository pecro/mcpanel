# Required. Absolute host path where mcpanel stores worlds, backups, and
# imports. mcpanel uses this exact string when constructing bind mounts on
# spawned world containers, so the path inside the panel container must
# equal the path on the host. Anywhere writable by PUID:PGID works.
MC_DATA_ROOT=/var/lib/mcpanel

# UID / GID for files created by mcpanel and spawned worlds.
# PUID=1000
# PGID=1000

# Timezone used by the panel and inside spawned worlds.
# TZ=America/New_York

# Hostname shown to players as the connect string in the panel UI.
# MINECRAFT_HOSTNAME=localhost

# Host port range allocated to spawned world containers.
# MC_PORT_RANGE_START=35550
# MC_PORT_RANGE_END=35559

# Host port the panel UI listens on.
# MCPANEL_HTTP_PORT=8000

# Optional: Apprise endpoint for the dual-awake watchdog. Leave empty to
# only log events.
# APPRISE_URL=
